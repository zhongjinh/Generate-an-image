# 复制到项目根目录为 .env，并替换所有 <> 占位符
# cp deploy/baota/env.production.example .env

APP_ENV=production
HOST=127.0.0.1
PORT=8765

# 宝塔 MySQL 中创建的数据库
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=diagram_user
MYSQL_PASSWORD=<数据库密码>
MYSQL_DATABASE=diagram_generator

# 随机字符串（可用: openssl rand -hex 32）
JWT_SECRET=<随机64字符>
JWT_EXPIRE_HOURS=168

# 管理员（生产勿用 admin 用户名，密码至少12位）
ADMIN_USERNAME=<自定义用户名如 ops_mgr_2026>
ADMIN_PASSWORD=<至少12位强密码>

LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=30

# 前后端必须一致（构建前端时 VITE_APP_CLIENT_TOKEN 填相同值）
APP_CLIENT_TOKEN=<随机32+字符>

ALLOW_SHOP_DEMO=0
REGISTER_FREE_COUNT=1
CONVERT_API_KEY=<随机字符串>
CONVERT_PORT=5000
PUBLIC_CONVERT=0

# QQ 邮箱 SMTP（smtp.qq.com 需用授权码，不是 QQ 密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=<你的QQ邮箱>
SMTP_PASSWORD=<QQ邮箱授权码>
SMTP_FROM=<你的QQ邮箱>
SMTP_FROM_NAME=图表在线生成器
SMTP_USE_TLS=1

# 可选 AI
DEEPSEEK_API_KEY=

# 你的域名（必须 https）
CORS_ORIGINS=https://diagram.example.com
TRUSTED_HOSTS=diagram.example.com
BEHIND_CLOUDFLARE=0
INTERNAL_API_SECRET=
