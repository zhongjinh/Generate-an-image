# ============================================================
# .env.example — 配置模板（全部必填，留空则无法启动）
# ============================================================
# 使用：复制为 .env 并填写实际值
#   cp .env.example .env
# ============================================================

# 环境: development | production
APP_ENV=development

# 服务器监听地址
HOST=127.0.0.1

# 服务器端口
PORT=8765

# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=diagram_generator

# JWT 签名密钥（建议使用 32 位以上随机字符串）
JWT_SECRET=

# JWT 有效期（小时，默认 168 = 7 天）
JWT_EXPIRE_HOURS=168

# 管理员账号 admin 的密码
ADMIN_PASSWORD=

# 管理员登录用户名（生产环境勿用 admin/root 等常见名）
ADMIN_USERNAME=admin

# 登录失败锁定：次数 / 锁定时长（分钟）
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=30

# 前端 API 客户端令牌（与 VITE_APP_CLIENT_TOKEN 一致，生产环境必填）
APP_CLIENT_TOKEN=

# 演示发卡（生产必须为 0，会绕过支付）
ALLOW_SHOP_DEMO=1

# 新用户注册赠送的免费生成次数
REGISTER_FREE_COUNT=1

# 转换服务 API 密钥
CONVERT_API_KEY=

# 转换服务端口（独立转换服务 api_server.py 使用）
CONVERT_PORT=5000

# 是否公开转换接口: 1=无需鉴权, 0=需要 API Key
PUBLIC_CONVERT=1

# 邮件 SMTP（注册验证码）
# 开发调试可设 SMTP_HOST=console，验证码会打印在后端控制台
# QQ 邮箱示例: SMTP_HOST=smtp.qq.com, SMTP_PORT=587, SMTP_USE_TLS=1
# QQ 邮箱 SSL: SMTP_HOST=smtp.qq.com, SMTP_PORT=465, SMTP_USE_TLS=0
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=dev@example.com
SMTP_PASSWORD=dev
SMTP_FROM=dev@example.com
# 发件人显示名称（收件箱里看到的名字，支持中文）
SMTP_FROM_NAME=图表在线生成器
SMTP_USE_TLS=1

# 可选：PlantUML SVG 渲染服务（序列图），默认 https://www.plantuml.com/plantuml/svg/
# PLANTUML_SERVER=http://127.0.0.1:8080/svg/

# DeepSeek AI（流程图/架构图/活动图/类图/序列图 自然语言转 JSON，可选）
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 支付宝配置（可选，未配置则使用本地购买/兑换码）
# 应用ID（在支付宝开放平台创建应用后获取）
ALIPAY_APP_ID=
# 商户私钥（RSA2 签名，去掉头尾和换行）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥（用于验签，去掉头尾和换行）
ALIPAY_PUBLIC_KEY=
# 异步通知地址（必须是公网可访问的 HTTPS 地址）
ALIPAY_NOTIFY_URL=
# 同步跳转地址（支付成功后跳转）
ALIPAY_RETURN_URL=

# ── Cloudflare 部署（生产环境 APP_ENV=production 时建议配置） ──
# 前端域名白名单（逗号分隔），Cloudflare Pages 同域代理时可留空
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=

# 允许的 Host 头（逗号分隔），API 子域名
# TRUSTED_HOSTS=api.yourdomain.com
TRUSTED_HOSTS=

# 是否经 Cloudflare 代理: 0 | 1
BEHIND_CLOUDFLARE=0

# Pages Functions → 后端 内部密钥（随机 32+ 字符，前后端一致）
INTERNAL_API_SECRET=

# 前端环境变量（Cloudflare Pages / npm run build 前设置）
# VITE_APP_CLIENT_TOKEN=<与 APP_CLIENT_TOKEN 相同>
# VITE_ADMIN_PATH=/console-7k9m2x   （管理后台隐藏路径，勿公开）
