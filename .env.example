# ============================================================
# .env.example — 配置项说明模板
# ============================================================
# 作用：列出所有可配置项及说明，提交到 Git 供团队参考
# 使用：复制为 .env 并填写实际值
#   cp .env.example .env
# ============================================================

# 环境: development | production
APP_ENV=development

# 服务器监听地址（开发 127.0.0.1，生产 0.0.0.0）
HOST=127.0.0.1

# 服务器端口
PORT=8765

# JWT 密钥
#   开发环境：留空则自动生成（重启后 token 失效），或填写固定值方便调试
#   生产环境：必须设置强密钥，否则启动报错
JWT_SECRET=

# 管理员密码
#   开发环境：留空则使用 admin123
#   生产环境：留空则启动时随机生成并打印（仅显示一次）
ADMIN_PASSWORD=

# 新用户注册赠送的免费生成次数
REGISTER_FREE_COUNT=1

# 转换服务 API 密钥
#   开发环境：留空则自动生成
#   生产环境：必须设置，否则启动报错
CONVERT_API_KEY=

# 转换服务端口
CONVERT_PORT=5000

# 是否公开转换接口（1=无需鉴权，0=需要 API Key）
#   开发环境建议 1，生产环境建议 0
PUBLIC_CONVERT=1
