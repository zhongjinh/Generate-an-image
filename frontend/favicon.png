<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea"/>
      <stop offset="100%" style="stop-color:#764ba2"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffd700"/>
      <stop offset="100%" style="stop-color:#ff8c00"/>
    </linearGradient>
    <linearGradient id="bar1" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#a8edea"/>
      <stop offset="100%" style="stop-color:#67d4d4"/>
    </linearGradient>
    <linearGradient id="bar2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#89f7fe"/>
      <stop offset="100%" style="stop-color:#66a6ff"/>
    </linearGradient>
  </defs>
  <!-- 圆角方形背景 -->
  <rect x="4" y="4" width="120" height="120" rx="24" ry="24" fill="url(#bg)"/>
  <!-- 图表柱子 - 四根渐变色柱子 -->
  <rect x="22" y="78" width="14" height="28" rx="3" fill="url(#bar1)" opacity="0.85"/>
  <rect x="42" y="58" width="14" height="48" rx="3" fill="url(#bar2)" opacity="0.85"/>
  <rect x="62" y="42" width="14" height="64" rx="3" fill="rgba(255,255,255,0.85)"/>
  <rect x="82" y="26" width="14" height="80" rx="3" fill="url(#accent)"/>
  <!-- 上升趋势线 -->
  <path d="M29 74 C40 68, 49 54, 56 50 C63 46, 69 38, 76 34 C83 30, 89 24, 96 20"
        stroke="#ffd700" stroke-width="3.5" fill="none" stroke-linecap="round"/>
  <!-- 趋势线上的亮点 -->
  <circle cx="29" cy="74" r="3.5" fill="#ffd700"/>
  <circle cx="49" cy="54" r="3.5" fill="#ffd700"/>
  <circle cx="69" cy="38" r="3.5" fill="#ffd700"/>
  <circle cx="89" cy="24" r="3.5" fill="#ffd700"/>
  <!-- 箭头 -->
  <polygon points="93,16 100,18 95,24" fill="#ffd700"/>
  <!-- 右上角装饰星 -->
  <g transform="translate(104, 14)" fill="#fff" opacity="0.6">
    <path d="M0,-5 L1.5,-1.5 L5,0 L1.5,1.5 L0,5 L-1.5,1.5 L-5,0 L-1.5,-1.5 Z"/>
  </g>
  <!-- 底部装饰线 -->
  <line x1="22" y1="108" x2="96" y2="108" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
</svg>