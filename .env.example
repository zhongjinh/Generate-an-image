# ============================================================
# .env.example — 配置模板（全部必填，留空则无法启动）
# ============================================================
# 使用：复制为 .env 并填写实际值
#   cp .env.example .env
# ============================================================

# 环境: development | production
APP_ENV=development

# 服务器监听地址
HOST=127.0.0.1

# 服务器端口
PORT=8765

# JWT 签名密钥（建议使用 32 位以上随机字符串）
JWT_SECRET=

# 管理员账号 admin 的密码
ADMIN_PASSWORD=

# 新用户注册赠送的免费生成次数
REGISTER_FREE_COUNT=1

# 转换服务 API 密钥
CONVERT_API_KEY=

# 转换服务端口（独立转换服务 api_server.py 使用）
CONVERT_PORT=5000

# 是否公开转换接口: 1=无需鉴权, 0=需要 API Key
PUBLIC_CONVERT=1

# 可选：PlantUML SVG 渲染服务（序列图），默认 https://www.plantuml.com/plantuml/svg/
# PLANTUML_SERVER=http://127.0.0.1:8080/svg/
